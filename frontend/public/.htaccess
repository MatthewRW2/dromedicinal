Options -Indexes
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # ── Archivos y directorios reales: servir tal cual ────────────────────────
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # ── RSC prefetch: Next.js 16 solicita __next.HASH.seg1.seg2.txt  ──────────
  # pero el archivo existe en  __next.HASH/seg1/seg2.txt
  # Reglas en orden de mayor a menor profundidad para evitar capturas cortas

  # 3 niveles: __next.H.a.b.c.txt → __next.H/a/b/c.txt
  RewriteRule ^(.*)/__next\.([^./]+)\.([^./]+)\.([^./]+)\.([^./]+)\.txt$ $1/__next.$2/$3/$4/$5.txt [L]

  # 2 niveles: __next.H.a.b.txt → __next.H/a/b.txt
  RewriteRule ^(.*)/__next\.([^./]+)\.([^./]+)\.([^./]+)\.txt$ $1/__next.$2/$3/$4.txt [L]

  # 1 nivel: __next.H.a.txt → __next.H/a.txt
  RewriteRule ^(.*)/__next\.([^./]+)\.([^./]+)\.txt$ $1/__next.$2/$3.txt [L]

  # ── Forzar barra final en rutas sin extensión ─────────────────────────────
  RewriteCond %{REQUEST_URI} !\.[a-zA-Z0-9]{1,5}$
  RewriteCond %{REQUEST_URI} !/$
  RewriteRule ^(.+)$ /$1/ [R=301,L]
</IfModule>

ErrorDocument 404 /404/index.html

# php -- BEGIN cPanel-generated handler, do not edit
# Set the "ea-php83" package as the default "PHP" programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php83___lsphp .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
